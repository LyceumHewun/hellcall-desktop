{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hellcall Desktop",
  "version": "1.0.0",
  "identifier": "cc.lyceum.hellcall-desktop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "hellcall-desktop",
        "width": 1024,
        "height": 720,
        "center": true,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "fullscreen": false,
        "maximized": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFBMUEwNzg4MUQ2Q0M5RApSV1Nkek5hQmVLQ2hBZkhlQW5JUmEzV09La3picDZDVm8zbnowZGZkU3orZHNsb2ttN3pXQi8wMwo=",
      "endpoints": [
        "https://gist.githubusercontent.com/LyceumHewun/c3d90efad62c0aa9b93e0df5f38dcc73/raw/hellcall_desktop_updater.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "lib/": "",
      "audio/": "audio/"
    },
    "windows": {}
  }
}
